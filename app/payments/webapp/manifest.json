{
  "_version": "1.85.0",
  "sap.app": {
    "id": "payments",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.25.0",
      "toolsId": "ebca79ab-481a-4cee-9f4d-7f115c4301f4"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/payment/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": false,
    "dependencies": {
      "minUI5Version": "1.148.1",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {},
        "sap.ui.unified": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "bundleUrl": "i18n/i18n.properties",
        "supportedLocales": [
          "en"
        ],
        "fallbackLocale": "en"
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "PaymentFilesList",
          "target": "PaymentFilesList"
        },
        {
          "pattern": "PaymentFiles({key}):?query:",
          "name": "PaymentFilesObjectPage",
          "target": "PaymentFilesObjectPage"
        }
      ],
      "targets": {
        "PaymentFilesList": {
          "type": "Component",
          "id": "PaymentFilesList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/PaymentFiles",
              "variantManagement": "Page",
              "navigation": {
                "PaymentFiles": {
                  "detail": {
                    "route": "PaymentFilesObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "actions": {
                    "UploadXML": {
                      "press": "payments.ext.controller.ListReportExt.onUploadXML",
                      "visible": true,
                      "enabled": true,
                      "requiresSelection": false,
                      "text": "Upload XML & Convert"
                    }
                  },
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  }
                }
              }
            }
          }
        },
        "PaymentFilesObjectPage": {
          "type": "Component",
          "id": "PaymentFilesObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/PaymentFiles",
              "content": {
                "header": {
                  "actions": {
                    "payload": {
                      "press": "payments.ext.controller.payload.submit",
                      "visible": true,
                      "enabled": true,
                      "requiresSelection": false,
                      "text": "submit"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}
